# MemoryVest Environment Variables Template
# Copy this file to .env and fill in the values below

# EverMemOS setup
# This needs to point to your running EverMemOS instance
EVERMEMOS_API_URL=http://localhost:1995/api/v1

# OpenRouter API Key (Required for structured extraction and report generation)
OPENROUTER_API_KEY=your-openrouter-api-key-here
LLM_MODEL=openai/gpt-5.4 # Alternative: x-ai/grok-4

# SQLite Database path (Defaults to memoryvest.db)
DB_PATH=memoryvest.db

# Optional APIs for Market/News data
# (Currently using mock data for MVP, but you can set these for future use)
MARKET_API_KEY=
NEWS_API_KEY=

# Delivery Service Setup (Gmail Example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# For Gmail, you must use an "App Password" (generated in your Google Account Security settings)
SMTP_USER=your.personal.email@gmail.com
SMTP_PASS=your-16-digit-app-password
SENDER_EMAIL=your.personal.email@gmail.com
